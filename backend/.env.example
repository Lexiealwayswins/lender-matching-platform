# =============================================================================
# Lender Matching Platform - .env.example
# Copy this file to .env and modify the values for your environment.
# Never commit the real .env file to version control.
# =============================================================================

# --------------------- Database Configuration ---------------------
DATABASE_URL=postgresql://postgres:postgres123456@localhost:5432/lender_matching

# PostgreSQL Docker settings
POSTGRES_DB=lender_matching
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123456
POSTGRES_PORT=5432

# --------------------- Application Settings ---------------------
ENVIRONMENT=development

# --------------------- Hatchet Workflow Configuration ---------------------
# These settings are only needed if you want to use the Hatchet orchestration workflow.
# You can obtain these values from https://hatchet.run after creating an account.

HATCHET_CLIENT_TOKEN=your_real_token_here
HATCHET_SERVER_URL=https://api.hatchet.run
HATCHET_DEBUG=false